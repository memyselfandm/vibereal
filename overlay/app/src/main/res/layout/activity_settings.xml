<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Hub URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hub URL"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editHubUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://10.41.41.237:41237"
            android:inputType="textUri"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:singleLine="true" />

        <!-- Hub API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hub API Key (optional)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editHubApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Leave empty if hub auth is disabled"
            android:inputType="textPassword"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:singleLine="true" />

        <!-- ElevenLabs API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ElevenLabs API Key"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editElevenLabsApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk_..."
            android:inputType="textPassword"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:singleLine="true" />

        <!-- Voice ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ElevenLabs Voice ID"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editVoiceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="C92s6vssSLlabgIln1iY"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:singleLine="true" />

        <!-- Model ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ElevenLabs Model ID"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editModelId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="eleven_turbo_v2_5"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="32dp"
            android:singleLine="true" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btnTestConnection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Connection"
            android:backgroundTint="@color/surface"
            android:textColor="@color/accent"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:backgroundTint="@color/accent"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
